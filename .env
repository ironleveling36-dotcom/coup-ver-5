# ──────────────────────────────────────────────────────────────────────────────
# Coupon Selling Bot — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to GitHub.
# On Railway, add these in the service "Variables" tab.
# ──────────────────────────────────────────────────────────────────────────────

# ── Telegram (REQUIRED) ──
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=YourBotUsername            # without @, used for referral links

# Role bootstrap. SUPER_ADMIN_IDS have full access and can never be locked out.
SUPER_ADMIN_IDS=123456789               # comma-separated numeric IDs
SUPPORT_IDS=                            # optional: comma-separated support staff
ADMIN_IDS=                              # legacy — promoted to super admins
ADMIN_CHAT_ID=123456789                 # where sale/recharge/alerts are sent

# ── MongoDB (REQUIRED) ──
# Get a free cluster at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=coupon_bot

# ── Gmail (auto wallet recharge verification) ──
# Use a Gmail App Password (16 chars), NOT your normal password.
GMAIL_ADDRESS=youremail@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop
IMAP_HOST=imap.gmail.com
SENDER_FILTER=                          # optional: e.g. alerts@hdfcbank.net
EMAIL_LOOKBACK_HOURS=48

# ── Payment ──
UPI_ID=yourname@upi
PAYEE_NAME=My Coupon Store
GENERATE_DYNAMIC_QR=true                # show a scannable UPI QR on recharge

# ── Force-join channel (leave blank to disable; editable in the admin panel) ──
# The BOT MUST be an ADMIN of this channel for membership checks to work.
FORCE_CHANNEL=                          # @yourchannel  or  -1001234567890
FORCE_CHANNEL_URL=                      # optional public join link

# ── Reseller program ──
RESELLER_FEE=500
RESELLER_AUTO_APPROVE=false             # true = activate instantly after payment
RESELLER_ENABLED=true                   # false = hide "Become Reseller" from all users

# ── Admin revenue withdrawals ──
WITHDRAWAL_COMMISSION_PCT=10            # super-admin commission % on withdrawals (editable in-app)

# ── Referral / affiliate ──
REFERRAL_ENABLED=true
REFERRAL_SIGNUP_BONUS=10
REFERRAL_COMMISSION_PCT=5
REFERRAL_WELCOME_BONUS=0

# ── Bot branding ──
BOT_NAME=CouponBot
CURRENCY_SYMBOL=₹
SUPPORT_USERNAME=                        # optional support handle (without @)

# ── Security / rate limiting ──
RATE_LIMIT_ACTIONS=20
RATE_WINDOW_SECONDS=10
FRAUD_FAILED_TXN_LIMIT=5
TXN_ATTEMPT_COOLDOWN=15

# ── Low stock + daily report ──
LOW_STOCK_THRESHOLD=5
LOW_STOCK_CHECK_INTERVAL=300
DAILY_REPORT_HOUR=23
DAILY_REPORT_MINUTE=55
TIMEZONE=Asia/Kolkata
PAGE_SIZE=6

# ── Behavior ──
PAYMENT_TIMEOUT_MINUTES=30
LOG_LEVEL=INFO
MAINTENANCE_MODE=false
ANIMATIONS_ENABLED=true
MAX_BULK_QTY=100

# ── Webhook (leave blank for polling — recommended on Railway free plan) ──
WEBHOOK_URL=
PORT=8443
